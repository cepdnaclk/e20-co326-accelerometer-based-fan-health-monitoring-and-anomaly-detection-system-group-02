        "format": "<style>\n/* ── Global Dark Theme Overrides ── */\n.nr-dashboard-theme .nr-dashboard-template {\n  background: transparent !important;\n}\nmd-toolbar {\n  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%) !important;\n  box-shadow: 0 4px 20px rgba(108,99,255,0.3) !important;\n}\nmd-toolbar .nr-dashboard-toolbar-title {\n  font-weight: 700 !important;\n  letter-spacing: 1.5px !important;\n  text-transform: uppercase !important;\n  font-size: 18px !important;\n  background: linear-gradient(90deg, #6C63FF, #00d2ff) !important;\n  -webkit-background-clip: text !important;\n  -webkit-text-fill-color: transparent !important;\n}\n.nr-dashboard-cardpanel {\n  background: #0f0f1a !important;\n}\n.nr-dashboard-tab {\n  background: #0f0f1a !important;\n}\nnr-dashboard-sidebar {\n  background: #16213e !important;\n}\n.nr-dashboard-theme ui-card-panel {\n  background: #16213e !important;\n  border: 1px solid rgba(108,99,255,0.15) !important;\n  border-radius: 16px !important;\n  box-shadow: 0 8px 32px rgba(0,0,0,0.3) !important;\n  margin: 6px !important;\n  transition: transform 0.3s ease, box-shadow 0.3s ease !important;\n}\n.nr-dashboard-theme ui-card-panel:hover {\n  box-shadow: 0 12px 40px rgba(108,99,255,0.2) !important;\n}\n.nr-dashboard-theme .nr-dashboard-theme-border {\n  border-color: #2a2a4a !important;\n}\n.nr-dashboard-groupname {\n  color: #a8a8d0 !important;\n  font-weight: 600 !important;\n  font-size: 13px !important;\n  letter-spacing: 0.8px !important;\n  text-transform: uppercase !important;\n  padding: 8px 12px !important;\n}\n/* Chart styling */\n.chart-group .nr-dashboard-widget canvas {\n  border-radius: 12px;\n}\n/* Hide CSS group */\n.css-group { display: none !important; height: 0 !important; overflow: hidden !important; }\n/* Scrollbar */\n::-webkit-scrollbar { width: 6px; }\n::-webkit-scrollbar-track { background: #0f0f1a; }\n::-webkit-scrollbar-thumb { background: #6C63FF; border-radius: 3px; }\n</style>",
