    {
        "id": "bff6283d0b3f506e",
        "type": "ui_template",
        "z": "480eabb870c38958",
        "group": "3645609b25aea338",
        "name": "Alert Display",
        "order": 1,
        "width": "12",
        "height": "3",
        "format": "<div id=\"alertBox\" style=\"\n    display:flex;\n    align-items:center;\n    gap:20px;\n    padding:20px 28px;\n    border-radius:16px;\n    border:1px solid {{msg.border}};\n    background:{{msg.bg}};\n    transition: all 0.4s cubic-bezier(0.4,0,0.2,1);\n    box-shadow: 0 0 30px {{msg.glow}};\n\">\n    <div style=\"font-size:40px;filter:drop-shadow(0 0 8px {{msg.glow}});\">{{msg.icon}}</div>\n    <div style=\"flex:1;\">\n        <div style=\"font-size:22px;font-weight:800;color:{{msg.color}};letter-spacing:2px;\">{{msg.payload}}</div>\n        <div style=\"font-size:12px;color:#7a7aaa;margin-top:4px;letter-spacing:0.5px;\">{{msg.subtitle}}</div>\n    </div>\n    <div style=\"padding:6px 16px;border-radius:20px;border:1px solid {{msg.border}};background:rgba(0,0,0,0.2);\">\n        <span style=\"color:{{msg.color}};font-size:11px;font-weight:700;letter-spacing:1px;\">LIVE</span>\n    </div>\n</div>\n\n<script>\n(function(scope) {\n    let blink = null;\n    scope.$watch('msg', function(msg) {\n        if (!msg) return;\n        const box = document.getElementById('alertBox');\n        if (blink) { clearInterval(blink); blink = null; }\n        if (msg.flash === true) {\n            let v = true;\n            blink = setInterval(function() {\n                if (!box) return;\n                box.style.opacity = v ? '0.4' : '1';\n                v = !v;\n            }, 600);\n        } else {\n            if (box) box.style.opacity = '1';\n        }\n    });\n})(scope);\n</script>",
        "storeOutMessages": true,
        "fwdInMessages": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 1200,
        "y": 500,
        "wires": [
            []
        ]
    },
    {
        "id": "7969ea47d34447f2",
        "type": "function",
        "z": "480eabb870c38958",
        "name": "Fan ON/OFF Timeout",
        "func": "if (context.get('timer')) {\n    clearTimeout(context.get('timer'));\n}\n\nconst timer = setTimeout(function() {\n    node.send({\n        payload: \"OFF\",\n        color: \"#ff4757\",\n        glow: \"rgba(255,71,87,0.5)\",\n        ringBg: \"rgba(255,71,87,0.1)\"\n    });\n}, 3000);\n\ncontext.set('timer', timer);\n\nmsg.payload = \"ON\";\nmsg.color = \"#00d264\";\nmsg.glow = \"rgba(0,210,100,0.5)\";\nmsg.ringBg = \"rgba(0,210,100,0.1)\";\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 580,
        "y": 660,
        "wires": [
            [
                "fde2ace3044ebf3d"
            ]
        ]
    },
    {
        "id": "fde2ace3044ebf3d",
        "type": "ui_template",
        "z": "480eabb870c38958",
        "group": "6e9ea93255d69f23",
        "name": "Fan ON/OFF Display",
        "order": 1,
        "width": "6",
        "height": "5",
        "format": "<div style=\"display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;gap:16px;padding:10px 0;\">\n    <div style=\"position:relative;\">\n        <div style=\"\n            width:110px;height:110px;border-radius:50%;\n            background:radial-gradient(circle, {{msg.ringBg}} 0%, transparent 70%);\n            position:absolute;top:-10px;left:-10px;\n            animation: pulse-ring 2s ease-out infinite;\n        \"></div>\n        <div style=\"\n            width:90px;height:90px;border-radius:50%;\n            background:linear-gradient(135deg, {{msg.color}}, {{msg.color}}cc);\n            display:flex;align-items:center;justify-content:center;\n            font-size:26px;font-weight:800;color:white;\n            box-shadow: 0 0 30px {{msg.glow}}, inset 0 -2px 6px rgba(0,0,0,0.2);\n            transition: all 0.5s cubic-bezier(0.4,0,0.2,1);\n            position:relative;\n            letter-spacing:2px;\n        \">{{msg.payload}}</div>\n    </div>\n    <div style=\"font-size:11px;color:#7a7aaa;font-weight:600;letter-spacing:2px;text-transform:uppercase;\">Fan Power</div>\n</div>\n<style>\n@keyframes pulse-ring {\n    0% { transform:scale(0.9); opacity:1; }\n    100% { transform:scale(1.4); opacity:0; }\n}\n</style>",
